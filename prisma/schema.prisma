generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Aluno {
  id           Int    @id @default(autoincrement())
  nome         String
  email        String @unique
  telefone     String?
  curso        String?
  aptoEstagio  Boolean @default(true)

  candidaturas Candidatura[]
}

model Empresa {
  id        Int    @id @default(autoincrement())
  nome      String
  cnpj      String @unique
  email     String
  telefone  String?

  aprovada  Boolean @default(false)
  ativa     Boolean @default(true)

  vagas     Vaga[]
}

model Vaga {
  id           Int    @id @default(autoincrement())
  titulo       String
  descricao    String
  requisitos   String?
  bolsa        Float?

  empresaId    Int
  empresa      Empresa @relation(fields: [empresaId], references: [id])

  candidaturas Candidatura[]
}

model Candidatura {
  id      Int @id @default(autoincrement())

  alunoId Int
  vagaId  Int

  status  StatusCandidatura @default(EM_ANALISE)

  aluno   Aluno @relation(fields: [alunoId], references: [id])
  vaga    Vaga  @relation(fields: [vagaId], references: [id])
}

enum StatusCandidatura {
  EM_ANALISE
  APROVADO
  REPROVADO
}